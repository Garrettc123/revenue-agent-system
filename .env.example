# Revenue Agent System - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Stripe API Keys (required for payment processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (required for checkout sessions)
STRIPE_STARTER_PRICE_ID=price_starter_id_here
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_id_here
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id_here

# Application URL (used for Stripe redirect URLs)
APP_URL=http://localhost:5000

# Server Port
PORT=5000

# Database (optional - app uses mock data if not configured)
DATABASE_URL=postgresql://user:password@localhost:5432/revenue_agent

# Optional: AI/Agent keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Monitoring
SENTRY_DSN=your_sentry_dsn_here
